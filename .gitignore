# Python
__pycache__/
*.py[cod]
.venv/
.ipynb_checkpoints/

# Data: keep the folders (via .gitkeep), ignore their contents. Raw data is
# never committed; everything downstream is a reproducible transformation of it.
data/**
!data/**/
!data/**/.gitkeep

# Model artifacts (regenerated by training)
models/*
!models/.gitkeep
